# =============================================================================
# Minepanel Environment Configuration
# =============================================================================
# Copy this file to .env and configure your values
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (Required)
# -----------------------------------------------------------------------------
# First access now uses the web UI to create the initial admin account.
JWT_SECRET=                                    # Generate with: openssl rand -base64 32
JWT_EXPIRES_IN=2d                             # Access token TTL (e.g., 20s, 15m, 1h)
ALLOW_INSECURE_AUTH_COOKIES=false             # Set true only for HTTP/LAN setups (less secure)

# -----------------------------------------------------------------------------
# Password Recovery (Optional but recommended)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false                              # true for SMTPS/465, false for STARTTLS/587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Minepanel <no-reply@example.com>
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=60

# -----------------------------------------------------------------------------
# Directories
# -----------------------------------------------------------------------------
BASE_DIR=$PWD                                  # Base directory on host (required for Docker socket)

# Optional prefix for server compose project names (final name: <prefix>_<serverId>)
COMPOSE_PROJECT=

# -----------------------------------------------------------------------------
# URLs (Important for remote access and CORS)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000            # Must match browser URL (controls CORS)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8091

# Optional backend prefix, e.g. /api
BASE_PATH=
# Optional frontend prefix, e.g. /minepanel (build-time for frontend)
NEXT_PUBLIC_BASE_PATH=

# -----------------------------------------------------------------------------
# Language
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_LANGUAGE=en               # Options: en, es, nl, de, pl

# =============================================================================
# Configuration Examples
# =============================================================================

# Local access (default):
#   FRONTEND_URL=http://localhost:3000
#   NEXT_PUBLIC_BACKEND_URL=http://localhost:8091

# Remote access (by IP):
#   FRONTEND_URL=http://192.168.1.100:3000
#   NEXT_PUBLIC_BACKEND_URL=http://192.168.1.100:8091

# With domain and SSL:
#   FRONTEND_URL=https://minepanel.yourdomain.com
#   NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# With subpaths behind one domain:
#   FRONTEND_URL=https://mydomain.com/minepanel
#   NEXT_PUBLIC_BACKEND_URL=https://mydomain.com/api
#   BASE_PATH=/api
#   NEXT_PUBLIC_BASE_PATH=/minepanel

# External drive:
#   BASE_DIR=/mnt/external-drive/minepanel

# =============================================================================
# Network Settings
# =============================================================================
# Public IP, LAN IP, and Proxy settings are configured through the web UI
# at Settings → Network Settings and Settings → Proxy Settings

# -----------------------------------------------------------------------------
# Tunnels / External Access (Optional)
# -----------------------------------------------------------------------------
# Ngrok token to expose the Minepanel dashboard publicly on the web
NGROK_AUTHTOKEN=

